{
  "name": "bmad-codelens",
  "displayName": "BMad CodeLens",
  "description": "Adds CodeLens buttons above BMad story headers for quick workflow actions",
  "version": "0.6.0",
  "icon": "docs/images/icon.png",
  "publisher": "LucaLanziani",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LucaLanziani/bmad-codelens.git",
    "directory": "tools/bmad-codelens"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "AI",
    "Chat"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:markdown"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "bmadCodelens.installBmad",
        "title": "BMad: Install"
      },
      {
        "command": "bmadCodelens.executeAction",
        "title": "BMad: Execute Story Action"
      }
    ],
    "configuration": {
      "title": "BMad CodeLens",
      "properties": {
        "bmadCodelens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable BMad Story CodeLens buttons"
        },
        "bmadCodelens.outputFolder": {
          "type": "string",
          "default": "_bmad-output",
          "description": "Relative path to the BMad output folder that contains implementation-artifacts/"
        },
        "bmadCodelens.bmadFolder": {
          "type": "string",
          "default": "_bmad",
          "description": "Relative path to the BMad installation folder. When this folder exists, the 'Install BMad' status bar button is hidden."
        },
        "bmadCodelens.actions": {
          "type": "array",
          "default": [
            {
              "label": "Create Story",
              "commandPrefix": "/bmad-bmm-create-story",
              "behavior": "new-chat"
            },
            {
              "label": "Copy Story",
              "commandPrefix": "",
              "behavior": "clipboard"
            }
          ],
          "items": {
            "type": "object",
            "properties": {
              "label": {
                "type": "string",
                "description": "Button label shown in CodeLens"
              },
              "commandPrefix": {
                "type": "string",
                "description": "Slash command prefix (e.g. /bmad-bmm-create-story). Empty for plain copy."
              },
              "behavior": {
                "type": "string",
                "enum": [
                  "clipboard",
                  "chat",
                  "chat-submit",
                  "new-chat",
                  "new-chat-submit"
                ],
                "enumDescriptions": [
                  "Copy the command to the clipboard",
                  "Open chat with the command pre-filled (user presses Enter to submit)",
                  "Open chat and submit the command immediately",
                  "Open a new chat session with the command pre-filled (user presses Enter to submit)",
                  "Open a new chat session and submit the command immediately"
                ],
                "description": "Action behavior: copy to clipboard, open chat pre-filled, or open chat and submit"
              }
            },
            "required": [
              "label",
              "commandPrefix",
              "behavior"
            ]
          },
          "description": "List of actions to show as CodeLens buttons above each story"
        },
        "bmadCodelens.devStoryAction": {
          "type": "object",
          "default": {
            "label": "Dev Story",
            "commandPrefix": "/bmad-bmm-dev-story",
            "behavior": "new-chat"
          },
          "properties": {
            "label": {
              "type": "string",
              "description": "Button label shown in CodeLens"
            },
            "commandPrefix": {
              "type": "string",
              "description": "Slash command prefix sent to chat"
            },
            "behavior": {
              "type": "string",
              "enum": [
                "clipboard",
                "chat",
                "chat-submit",
                "new-chat",
                "new-chat-submit"
              ],
              "description": "Action behavior"
            }
          },
          "required": [
            "label",
            "commandPrefix",
            "behavior"
          ],
          "description": "Action shown on story implementation files with status 'ready-for-dev'"
        },
        "bmadCodelens.codeReviewAction": {
          "type": "object",
          "default": {
            "label": "Code Review",
            "commandPrefix": "/bmad-bmm-code-review",
            "behavior": "new-chat"
          },
          "properties": {
            "label": {
              "type": "string",
              "description": "Button label shown in CodeLens"
            },
            "commandPrefix": {
              "type": "string",
              "description": "Slash command prefix sent to chat"
            },
            "behavior": {
              "type": "string",
              "enum": [
                "clipboard",
                "chat",
                "chat-submit",
                "new-chat",
                "new-chat-submit"
              ],
              "description": "Action behavior"
            }
          },
          "required": [
            "label",
            "commandPrefix",
            "behavior"
          ],
          "description": "Action shown on story implementation files with status 'review'"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "vsce package --no-dependencies",
    "install:cursor": "cursor --install-extension bmad-codelens-$(node -p \"require('./package.json').version\").vsix",
    "install:vscode": "code --install-extension bmad-codelens-$(node -p \"require('./package.json').version\").vsix",
    "uninstall:cursor": "cursor --uninstall-extension LucaLanziani.bmad-codelens",
    "uninstall:vscode": "code --uninstall-extension LucaLanziani.bmad-codelens",
    "release": "npm run compile && npm run package"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.0"
  }
}
